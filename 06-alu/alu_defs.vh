`define ALU_ADD  3'b000   // ADD / SUB (sub=1 for subtraction)
`define ALU_SLL  3'b001   // Shift Left Logical
`define ALU_SLT  3'b010   // Set Less Than (signed)
`define ALU_SLTU 3'b011   // Set Less Than Unsigned
`define ALU_XOR  3'b100   // XOR
`define ALU_SR   3'b101   // Shift Right Logical / Arithmetic (sub=1 for arithmetic)
`define ALU_OR   3'b110   // OR
`define ALU_AND  3'b111   // AND
